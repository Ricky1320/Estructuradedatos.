#include <iostream>
#include "triangulo.h"

using namespace std;

int main()
{
    triangulo triangulito;
    cout << "el area del triangulo es "<< triangulito.calculararea(5, 6);
    return 0;
}

#include "triangulo.h"
triangulo::triangulo(void)
{
	base = 4;
	altura = 3;
}
//Declaracion del destructor
triangulo::~triangulo(void)
{
}
//Declaración del metodo - funcion
float triangulo::calculararea(float b, float h)
{
	area = (b * h) / 2;
	return area;
}


#pragma once
class triangulo
{
	// Atributos - Variables
	private:
		float base;
		float altura;
		float area;
	//Metodos - Funciones
	public:
		triangulo(void); //Constructor - asigna memoria 
		~triangulo(void); //Deestructor - libera memoria
	//Prototipos
	float calculararea(float b, float h);
};
