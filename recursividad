#include <iostream>
using namespace std;
int factorial(int n);
int sumanaturales(int a);
int potencia(int n, int a);

int main()
{
    int opcion;
do {
    cout << "Menu\n";
    cout << "1. Calcular factorial\n";
    cout << "2. Suma de N numeros naturales\n";
    cout << "3. Calcular la potencia de un numero\n";
    cout << "4. Salir\n";
    cin >> opcion;
    switch (opcion) {
        
        case 1: {
            int n;
            cout << "ingresar numero ";
            cin >> n;
            cout << "el factorial de " << n << " es " << factorial(n) << endl;
            break;
    }
        case 2: {
            int a;
            cout << "Introduce el número: ";
            cin >> a;
            cout << "la suma de " << a << " es " << sumanaturales(a) << endl;
            break;
    }
        case 3: {
            int n, a;
            cout << "Introduce la base: ";
            cin >> n;
            cout << "Introduce el exponente: ";
            cin >> a;
            cout << "La suma total de la serie es: " << potencia(n, a) << endl;
            break;
        }
        case 4:
            cout << "¡Hasta luego!\n";
            return 0;
            break;
        default:
            cout << "Opción no válida. Intenta de nuevo.\n";
            break;
}
} while (opcion != 4);
    
}

int factorial(int n) {
    if ((n == 0) || (n == 1))
        return 1;
    else return factorial(n - 1) * n;
}
int sumanaturales(int a) {
    if (a == 1)
        return 1;
    else return a + sumanaturales(a - 1);
}

int potencia(int n, int a) {
    if (a == 0)
        return 1;

    else return n * potencia(n, a - 1);
}
