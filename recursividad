int factorial(int n) {
    if ((n == 0) || (n == 1))
        return 1;
    else return factorial(n - 1) * n;
}

int mayor(int a, int b, int c){
    if (a == b && b == c) {
        cout << "Todos los números son iguales.\n";
        return 0;
    }
    else if (a > b && a > c) {
        cout << "El mayor número es: " << a << endl;
        return a;
    }
    else if (b > a && b > c) {
        cout << "El mayor número es: " << b << endl;
        return b;
    }
    else {
        cout << "El mayor número es: " << c << endl;
        return c;
    }
}

int ciclo(int x) {
    double suma = 0;
    for (int b = 1; b <= 10; ++b) {
        suma += pow(x, b);
    }
    cout << "La suma total de la serie es: " << suma << endl;
    return suma;
}
